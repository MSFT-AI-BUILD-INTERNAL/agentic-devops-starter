# AG-UI Server Configuration (GitHub Copilot SDK)

# GitHub Personal Access Token for Copilot SDK authentication.
# Required in production (App Service). In local dev, the SDK falls back
# to the logged-in GitHub CLI user (`gh auth login`).
# The token needs the `copilot` scope.
# GITHUB_TOKEN=ghp_...

# AG-UI Client Configuration
AGUI_SERVER_URL=http://127.0.0.1:5100/

# Server settings (all optional — defaults shown)
# COPILOT_API_HOST=0.0.0.0
# COPILOT_API_PORT=5100
# COPILOT_API_LOG_LEVEL=INFO
# COPILOT_API_SESSION_TIMEOUT=120.0

# Azure Monitor Tracing (optional)
# When set, traces, logs, and metrics are exported to Azure Application
# Insights via OpenTelemetry. Leave unset to disable tracing in local dev.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
# Optional: override the service name reported on every span.
# OTEL_SERVICE_NAME=agentic-devops-starter

# Azure Blob Storage (required for file upload feature)
# COPILOT_API_AZURE_STORAGE_BLOB_ENDPOINT=https://<account>.blob.core.windows.net
# COPILOT_API_AZURE_STORAGE_CONTAINER_NAME=uploads

# Azure AI Foundry BYOK (used only when the frontend Model selector is Foundry)
# AZURE_AI_PROJECT_ENDPOINT=https://jinspark-kr-foundry.services.ai.azure.com
# AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.3-codex
# FOUNDRY_AUTH_MODE=azure_identity  # auto | api_key | azure_identity
# FOUNDRY_API_KEY=<foundry-api-key>  # required only when FOUNDRY_AUTH_MODE=api_key
# FOUNDRY_WIRE_API=responses
