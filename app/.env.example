# AG-UI Server Configuration

# Azure OpenAI Configuration (Option 1 - Preferred)
AZURE_AI_PROJECT_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini
# Optional: If not using DefaultAzureCredential
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# OpenAI Configuration (Option 2 - Fallback)
# OPENAI_API_KEY=your-openai-api-key

# AG-UI Client Configuration
AGUI_SERVER_URL=http://127.0.0.1:5100/

# Microsoft Foundry / Azure Monitor Tracing (optional)
# When set, traces, logs, and metrics are exported to the Application Insights
# resource attached to your Microsoft Foundry (Azure AI Foundry) project via
# OpenTelemetry. Leave unset to disable tracing in local development.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
# Optional: override the service name reported on every span.
# OTEL_SERVICE_NAME=agentic-devops-starter
# Optional: include prompt/completion contents on agent spans (dev/test only).
# ENABLE_SENSITIVE_DATA=false
