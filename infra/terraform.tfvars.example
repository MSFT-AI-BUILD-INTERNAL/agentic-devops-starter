# Example terraform.tfvars for Azure App Service deployment
# Copy this file to terraform.tfvars and fill in your values

# Resource Group Configuration
resource_group_name = "rg-agentic-devops"

# Per-resource create toggles. All default to ``false`` so the stack
# references pre-existing resources and ``terraform apply`` is idempotent
# (re-runs do not fail with ``A resource with the ID ... already exists``).
# Flip a toggle to ``true`` only for the resources Terraform should create
# end-to-end on a greenfield deployment.
# create_resource_group   = false
# create_acr              = false
# create_app_service_plan = false
# create_log_analytics    = false
location            = "koreacentral"

# Azure Container Registry
# IMPORTANT: ACR name must be globally unique and alphanumeric only (no hyphens, underscores)
acr_name        = "acragenticdevops"  # Change this to a unique name
acr_sku         = "Standard"
acr_admin_enabled = false

# App Service Plan
app_service_plan_name = "asp-agentic-devops"
app_service_plan_sku  = "P1v3"  # Options: B1, B2, B3, P1v3, P2v3, P3v3

# App Service
# IMPORTANT: App Service name must be globally unique (becomes <name>.azurewebsites.net)
app_service_name = "app-agentic-devops"  # Change this to a unique name
backend_image_name = "agentic-devops-starter"

# Log Analytics Workspace
log_analytics_workspace_name = "log-agentic-devops"
log_analytics_sku            = "PerGB2018"
log_analytics_retention_days = 30

# Azure AI Foundry Configuration (Optional)
# If you have an Azure AI Foundry project, provide its resource ID for role assignments
# ai_foundry_resource_id = "/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<project-name>"
ai_foundry_resource_id = ""

# Application Configuration (Optional - can also be set via GitHub Secrets)
azure_ai_project_endpoint      = ""
azure_ai_model_deployment_name = ""
azure_openai_api_version       = "2024-02-15-preview"

# Tags
tags = {
  Environment = "Development"
  Project     = "Agentic DevOps Starter"
  ManagedBy   = "Terraform"
  Platform    = "Azure App Service"
}

# Virtual Network (for App Service VNet integration + Blob private endpoint)
vnet_name                       = "vnet-agentic-devops"
vnet_address_space              = "10.10.0.0/16"
app_integration_subnet_prefix   = "10.10.1.0/24"
private_endpoint_subnet_prefix  = "10.10.2.0/24"

# Azure Blob Storage for file uploads
# IMPORTANT: storage_account_name must be globally unique, 3-24 lowercase alphanumeric chars.
storage_account_name                  = "stagenticdevops"  # Change this to a unique name
uploads_container_name                = "uploads"
storage_replication_type              = "LRS"
storage_public_network_access_enabled = false  # Access only via private endpoint
storage_shared_access_key_enabled     = false  # Use managed identity / Entra ID only
